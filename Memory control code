    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div>
    <div class="panel">
      <h3>Export Memories</h3>
      <button class="btn">JSON</button>
      <button class="btn">Timeline</button>
      <button class="btn">Narrative</button>
