  <div class="footer">"Your mind is not data. It's a legacy."</div>
</div>

<!-- ============ MAIN ============ -->
<div class="main">

  <!-- LEFT CONTENT -->
  <div>
    <div class="header">
      <h1>Memory Control</h1>
      <p>Manage, edit, and export your memories</p>
    </div>

    <div class="search">
      <input placeholder="Search memories..." />
    </div>

    <div class="memories">
      <div class="memory">
        <div>
          <h3>my friend is girish</h3>
          <span>Jan 30, 2026</span>
        </div>
        <span class="badge">Private</span>
      </div>

      <div class="memory">
        <div>
          <h3>Naming my dog “Leo”</h3>
          <span>Jan 30, 2026</span>
        </div>
        <span class="badge">Private</span>
      </div>

      <div class="memory">
        <div>
          <h3>Switching to Remote Work Full-Time</h3>
          <span>Jan 30, 2026</span>
        </div>
        <span class="badge">Private</span>
      </div>

      <div class="memory">
        <div>
          <h3>Learning a New Programming Language</h3>
          <span>Jan 30, 2026</span>
        </div>
        <span class="badge">Private</span>
      </div>

      <div class="memory">
        <div>
          <h3>Moving to a Smaller Apartment</h3>
          <span>Jan 30, 2026</span>
        </div>
        <span class="badge">Private</span>
