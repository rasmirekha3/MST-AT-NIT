<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>SOUL-NET – What If...</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Inter,system-ui,sans-serif;
}

body{
  background:#0b0f14;
  color:#e5e7eb;
}

.app{
  display:flex;
  height:100vh;
}

/* ===== SIDEBAR ===== */
.sidebar{
  width:260px;
  background:#0e131a;
  padding:24px;
  display:flex;
  flex-direction:column;
}

.logo{
  display:flex;
  gap:10px;
  align-items:center;
}

.logo .icon{
  background:linear-gradient(135deg,#3b82f6,#06b6d4);
  padding:10px;
  border-radius:12px;
}

.logo h2{
  font-size:18px;
}

.logo span{
  font-size:12px;
  color:#9ca3af;
}

.welcome{
  margin:24px 0;
  color:#9ca3af;
}

nav a{
  display:flex;
  align-items:center;
  gap:10px;
  padding:10px 14px;
  margin-bottom:6px;
  border-radius:12px;
  color:#cbd5f5;
  cursor:pointer;
}

nav a.active,
nav a:hover{
  background:#111827;
}

.sidebar footer{
  margin-top:auto;
  font-size:12px;
  color:#6b7280;
  opacity:.8;
}

/* ===== MAIN ===== */
.main{
  flex:1;
  padding:32px;
}

/* Header */
.header h1{
  font-size:28px;
  display:flex;
  align-items:center;
  gap:10px;
}

.header p{
  color:#9ca3af;
  margin-top:6px;
}

/* Warning */
.warning{
  margin-top:22px;
  background:#111827;
  border:1px solid #facc15;
  border-radius:14px;
  padding:16px;
}

.warning strong{
  display:flex;
  align-items:center;
  gap:8px;
  color:#fde68a;
}

.warning span{
  display:block;
  margin-top:6px;
  color:#9ca3af;
  font-size:14px;
}

/* Card */
.card{
  margin-top:26px;
  background:linear-gradient(180deg,#0b1220,#0b0f14);
  border:1px solid #1f3a8a;
  border-radius:18px;
  padding:22px;
  max-width:820px;
}

.card h3{
  margin-bottom:14px;
  font-size:18px;
}

.select-box{
  width:100%;
  padding:16px;
  background:#111827;
  border:1px solid #1f2937;
  border-radius:14px;
  color:#9ca3af;
  appearance:none;
  cursor:pointer;
}
</style>
</head>

<body>

<div class="app">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="logo">
      <div class="icon">🧠</div>
      <div>
        <h2>SOUL-NET</h2>
        <span>Memory System</span>
      </div>
    </div>

    <p class="welcome">Welcome back,<br><b>girish</b></p>

    <nav>
      <a>🏠 Dashboard</a>
      <a>➕ Capture Decision</a>
      <a>🗂 Memory Vault</a>
      <a>🧩 Memory Graph</a>
      <a>💬 Talk to Avatar</a>
      <a class="active">🔮 What If...</a>
      <a>⚙ Memory Control</a>
      <a>🛡 Ethics & Privacy</a>
    </nav>

    <footer>
      “Your mind is not data. It's a legacy.”
    </footer>
  </aside>

  <!-- MAIN -->
  <main class="main">

    <div class="header">
      <h1>🔮 What If...</h1>
      <p>Explore alternate decision paths for reflection</p>
    </div>

    <div class="warning">
      <strong>⚠ Simulated for reflection, not prediction</strong>
      <span>
        This tool helps you think through alternatives — it cannot predict actual outcomes.
        Use it for learning, not regret.
      </span>
    </div>

    <div class="card">
      <h3>Select a Decision</h3>
      <select class="select-box">
        <option>Choose a decision to explore...</option>
        <option>Switching to Remote Work</option>
        <option>Learning a New Programming Language</option>
        <option>Moving to a Smaller Apartment</option>
      </select>
    </div>

  </main>

</div>

<script>
console.log("What If page loaded");
</script>

</body>
</html>
